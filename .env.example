# sticker-bot2 .env.example (limpo e documentado)
# Projeto: /home/dev/work/sticker-bot2
# Formato: cada variável tem destino principal no código + explicação.

# =========================
# Core / Admin / Web
# =========================
# Destino principal: src/services/ai.js
# O que faz: chave principal OpenAI para recursos multimodais/fallback.
OPENAI_API_KEY=***
# Destino principal: src/utils/adminUtils.js
# O que faz: admin principal (JID WhatsApp).
ADMIN_NUMBER=5511999999999@c.us
# Destino principal: src/utils/adminUtils.js
# O que faz: admins adicionais (csv).
ADMIN_NUMBERS=178108149825760@lid
# Destino principal: src/bot/scheduler.js
# O que faz: grupo padrão para envios automáticos.
AUTO_SEND_GROUP_ID=120363000000000000@g.us
# Destino principal: src/bot/messageHandler.js
# O que faz: lista de grupos permitidos para conversa (csv).
GROUP_CHAT_ALLOWED_IDS=120363000000000000@g.us,120363111111111111@g.us
# Destino principal: src/bot/messageHandler.js
# O que faz: DMs explicitamente permitidos (csv). Vazio = sem DMs.
STICKER_BOT_ALLOWED_DM_IDS=
# Destino principal: src/database/models/processing.js + src/paths.js
# O que faz: origem legada para migração de figurinhas antigas.
OLD_STICKERS_PATH=/mnt/nas/Media/Figurinhas/
# Destino principal: src/web/server.js
# O que faz: diretório base de mídia do WebServer.
STICKERS_DIR=/media/
# Destino principal: src/web/server.js + src/web/auth.js
# O que faz: ativa autologin de debug no painel web.
ADMIN_AUTOLOGIN_DEBUG=0
# Destino principal: src/web/server.js
# O que faz: usuário inicial do painel.
ADMIN_INITIAL_USERNAME=admin
# Destino principal: src/web/server.js
# O que faz: senha inicial do painel.
ADMIN_INITIAL_PASSWORD=***
# Destino principal: src/web/server.js e middlewares web
# O que faz: ativa analytics internos.
ENABLE_INTERNAL_ANALYTICS=0
# Destino principal: src/web/middlewares/csp.js
# O que faz: origem Umami permitida no CSP.
UMAMI_ORIGIN=https://analytics.example.com
# Destino principal: src/web/middlewares/csp.js
# O que faz: habilita script Cloudflare Insights no CSP.
ALLOW_CF_INSIGHTS=1
# Destino principal: src/bot/scheduler.js
# O que faz: timezone do agendador.
TIMEZONE=America/Sao_Paulo
# Destino principal: src/web/server.js
# O que faz: número do bot para links/integrações web.
BOT_WHATSAPP_NUMBER=5511999999999
# Destino principal: src/web/emailService.js
# O que faz: host SMTP.
SMTP_HOST=smtp.gmail.com
# Destino principal: src/web/emailService.js
# O que faz: porta SMTP.
SMTP_PORT=587
# Destino principal: src/web/emailService.js
# O que faz: se usa SMTP seguro.
SMTP_SECURE=false
# Destino principal: src/web/emailService.js
# O que faz: usuário SMTP.
SMTP_USER=your-email@example.com
# Destino principal: src/web/emailService.js
# O que faz: senha SMTP/app-password.
SMTP_PASS=***
# Destino principal: src/web/emailService.js
# O que faz: remetente padrão dos e-mails.
FROM_EMAIL=noreply@example.com
# Destino principal: src/web/emailService.js
# O que faz: URL base pública para links de confirmação.
BASE_URL=https://figurinhas.example.com
# Destino principal: src/commands/handlers/pack.js
# O que faz: URL pública para links de packs.
WEB_SERVER_URL=https://figurinhas.example.com
# Destino principal: src/web/server.js
# O que faz: segredo JWT da auth web.
JWT_SECRET=***
# Destino principal: src/web/server.js
# O que faz: segredo de sessão do painel.
SESSION_SECRET=***
# Destino principal: src/web/server.js + ecosystem.config.js
# O que faz: porta HTTP do WebServer.
PORT=3000

# =========================
# Histórico / GitHub / NSFW / Meme / Admin Watcher
# =========================
# Destino principal: src/services/messageHistoryRecovery.js
# O que faz: ativa recuperação de histórico.
HISTORY_RECOVERY_ENABLED=true
# Destino principal: src/services/messageHistoryRecovery.js
# O que faz: tamanho do lote de recuperação.
HISTORY_BATCH_SIZE=10
# Destino principal: src/services/messageHistoryRecovery.js
# O que faz: limite de mensagens por chat.
HISTORY_MAX_MESSAGES=50
# Destino principal: src/bot/index.js
# O que faz: ativa sincronização periódica de histórico.
HISTORY_PERIODIC_SYNC=false
# Destino principal: src/bot/index.js
# O que faz: intervalo (h) da sincronização periódica.
HISTORY_SYNC_INTERVAL_HOURS=24
# Destino principal: src/services/messageHistoryRecovery.js
# O que faz: chats específicos para sync (csv), opcional.
# HISTORY_SYNC_CHATS=120363123456789012@g.us,120363987654321098@g.us

# Destino principal: src/commands/handlers/issue.js
# O que faz: token para abrir issue no GitHub.
GITHUB_TOKEN=***
# Destino principal: src/commands/handlers/issue.js
# O que faz: linhas de log anexadas ao issue.
GITHUB_ISSUE_LOG_LINES=50

# Destino principal: src/services/nsfwExternal.js
# O que faz: provider(s) externos para moderação NSFW.
NSFW_EXTERNAL_PROVIDER=openai
# Destino principal: src/services/nsfwExternal.js
# O que faz: chave para endpoint de moderação OpenAI.
OPENAI_MODERATION_API_KEY=***
# Destino principal: src/services/nsfwExternal.js
# O que faz: modelo de moderação OpenAI.
OPENAI_MODERATION_MODEL=omni-moderation-latest
# Destino principal: src/services/nsfwExternal.js
# O que faz: score mínimo para classificação NSFW.
NSFW_OPENAI_MIN_SCORE=0.2
# Destino principal: src/services/nsfwFilter.js
# O que faz: thresholds locais das classes NSFW.
NSFW_LOCAL_PORN_THRESHOLD=0.6
NSFW_LOCAL_HENTAI_THRESHOLD=0.6
NSFW_LOCAL_SEXY_THRESHOLD=0.85

# Destino principal: src/plugins/memeGenerator.js
# O que faz: chave dedicada para geração de meme.
OPENAI_API_KEY_MEMECREATOR=***
# Destino principal: src/plugins/memeGenerator.js
# O que faz: parâmetros padrão de imagem de meme.
MEME_IMAGE_SIZE=1024x1024
MEME_IMAGE_QUALITY=low
# Destino principal: src/plugins/memeGenerator.js
# O que faz: override opcional do modelo de prompt.
# MEME_PROMPT_MODEL=gpt-4o-mini
# Destino principal: src/plugins/memeGenerator.js
# O que faz: idioma opcional para transcrição.
# MEME_TRANSCRIPTION_LANGUAGE=pt

# Destino principal: src/services/adminWatcher.js
# O que faz: auto-diagnóstico por mensagens de admin.
ADMIN_WATCHER_ENABLED=false
# Destino principal: src/services/adminWatcher.js
# O que faz: modelo usado no diagnóstico automático.
ADMIN_WATCHER_MODEL=gpt-4o-mini

# =========================
# Conversação (grupo)
# =========================
# Destino principal: src/services/conversationAgent.js
# O que faz: liga/desliga agente conversacional.
CONVERSATION_AGENT_ENABLED=1
# Destino principal: src/services/conversationAgent.js
# O que faz: nome da persona do bot.
CONVERSATION_PERSONA_NAME=Lia
# Destino principal: src/services/conversationAgent.js
# O que faz: aliases para acionamento textual (csv).
CONVERSATION_ALIASES=lia,bot,sticker-bot,sticker bot
# Destino principal: src/services/conversationAgent.js
# O que faz: limite de histórico recente enviado ao modelo.
CONVERSATION_HISTORY_LIMIT=8
# Destino principal: src/services/conversationAgent.js
# O que faz: cooldown entre respostas (ms).
CONVERSATION_COOLDOWN_MS=120000
# Destino principal: src/services/conversationAgent.js
# O que faz: mínimo de mensagens para responder sem menção.
CONVERSATION_MIN_MESSAGES=3
# Destino principal: src/services/conversationAgent.js
# O que faz: limite de caracteres por chunk.
CONVERSATION_MAX_RESPONSE_CHARS=1200
# Destino principal: src/services/ai.js
# O que faz: limite de tokens de saída.
CONVERSATION_MAX_TOKENS=700
# Destino principal: src/services/ai.js
# O que faz: força /no_think para evitar resposta vazia em modelos thinking.
CONVERSATION_FORCE_NO_THINK=1
# Destino principal: src/services/conversationAgent.js
# O que faz: delay entre chunks (ms).
CONVERSATION_REPLY_SPLIT_DELAY_MS=300
# Destino principal: src/services/conversationAgent.js
# O que faz: prompt sistêmico da persona.
CONVERSATION_SYSTEM_PROMPT=Você é {persona}, participante ativa do grupo {group}. Responda em português brasileiro natural e direto.
# Destino principal: src/services/conversationAgent.js
# O que faz: máximo de chunks por resposta padrão.
CONVERSATION_MAX_CHUNKS=2
# Destino principal: src/services/conversationAgent.js
# O que faz: máximo de chunks em pedidos detalhados.
CONVERSATION_MAX_CHUNKS_SPECIFIC=4
# Destino principal: src/services/conversationAgent.js
# O que faz: limite de chars no modo curto padrão.
CONVERSATION_DEFAULT_SHORT_MAX_CHARS=420
# Destino principal: src/services/conversationAgent.js
# O que faz: responde apenas com menção explícita quando ativo.
CONVERSATION_STRICT_MENTION_ONLY=1
# Destino principal: src/services/conversationAgent.js
# O que faz: injeta memória contextual na conversa.
CONVERSATION_ENABLE_MEMORY_CONTEXT=0
# Destino principal: src/services/ai.js
# O que faz: modelo principal de chat.
CONVERSATION_MODEL=Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf
# Destino principal: src/services/ai.js
# O que faz: api key do provider de chat.
CONVERSATION_API_KEY=***
# Destino principal: src/services/ai.js
# O que faz: base URL do provider de chat.
CONVERSATION_BASE_URL=http://192.168.20.24:8080/v1
# Destino principal: src/services/conversationAgent.js
# O que faz: número máximo de tentativas de sanitização.
CONVERSATION_SANITIZE_MAX_ATTEMPTS=1

# =========================
# Memory Bridge
# =========================
# Destino principal: src/client/memory-client.js
# O que faz: ativa cliente de memória persistente.
MEMORY_ENABLED=1
# Destino principal: src/client/memory-client.js
# O que faz: URL da API de memória.
MEMORY_API_URL=http://127.0.0.1:8766
# Destino principal: src/client/memory-client.js
# O que faz: timeout da API de memória (ms).
MEMORY_TIMEOUT_MS=3000
# Destino principal: src/client/memory-client.js
# O que faz: retries para chamadas de memória.
MEMORY_RETRY_COUNT=1
# Destino principal: src/memory-bridge/server.js
# O que faz: porta da memory bridge.
MEMORY_BRIDGE_PORT=8766
# Destino principal: src/memory-bridge/server.js
# O que faz: host bind da memory bridge.
MEMORY_BRIDGE_HOST=0.0.0.0
# Destino principal: src/memory-bridge/server.js
# O que faz: token de autenticação da memory bridge.
MEMORY_BRIDGE_TOKEN=***
# Destino principal: src/memory-bridge/store.js
# O que faz: caminho do sqlite da memory bridge.
MEMORY_BRIDGE_DB_PATH=storage/data/memory-bridge.db
# Destino principal: src/memory-bridge/llm.js
# O que faz: ativa LLM na memory bridge.
MEMORY_LLM_ENABLED=1
# Destino principal: src/memory-bridge/llm.js
# O que faz: endpoint completion do LLM da memory bridge.
MEMORY_LLM_URL=http://192.168.20.24:8080/v1/completions
# Destino principal: src/memory-bridge/llm.js
# O que faz: modelo do LLM na memory bridge.
MEMORY_LLM_MODEL=Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf
# Destino principal: src/memory-bridge/llm.js
# O que faz: timeout para LLM da memory bridge (ms).
MEMORY_LLM_TIMEOUT_MS=2500
# Destino principal: src/memory-bridge/llm.js
# O que faz: api key do endpoint LLM da memory bridge.
MEMORY_LLM_API_KEY=***

# =========================
# Baileys / Bridge WS
# =========================
# Destino principal: src/waAdapter.js
# O que faz: modo de autenticação WhatsApp (qr/pairing).
BAILEYS_AUTH_METHOD=pairing
# Destino principal: src/waAdapter.js
# O que faz: número usado para pairing code.
BAILEYS_PAIRING_PHONE_NUMBER=5511999999999
# Destino principal: src/server/bridge.js
# O que faz: porta do bridge websocket.
BAILEYS_WS_PORT=8765
# Destino principal: src/server/bridge.js
# O que faz: tokens permitidos no bridge (csv).
BAILEYS_ALLOWED_TOKENS=***
# Destino principal: src/waAdapter.js
# O que faz: URL do bridge websocket.
BAILEYS_WS_URL=ws://localhost:8765
# Destino principal: src/waAdapter.js
# O que faz: token cliente para conexão ao bridge.
BAILEYS_CLIENT_TOKEN=***
# Destino principal: src/paths.js
# O que faz: diretório de sessão/auth do Baileys.
BAILEYS_AUTH_DIR=storage/auth_info_baileys
# Destino principal: src/server/bridge.js
# O que faz: watchdog de silêncio do processo WPP (ms).
WS_WPP_MAX_SILENCE_MS=0
# Destino principal: src/server/bridge.js
# O que faz: limite de memória PSS do browser monitorado (MB).
WS_BROWSER_MAX_PSS_MB=3000

# =========================
# Debug / mídia
# =========================
# Destino principal: src/web/server.js
# O que faz: token temporário para endpoint debug de config.
DEBUG_BOT_CONFIG_TOKEN=change_debug_token
# Destino principal: src/bot/mediaProcessor.js
# O que faz: desativa análise multi-frame de webp animado.
DISABLE_MULTIFRAME_WEBP_ANALYSIS=false
