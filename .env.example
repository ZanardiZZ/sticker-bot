# === Credenciais e API ===
OPENAI_API_KEY=

# === Comportamento do Bot ===
# true para bloquear conteúdo NSFW; false para apenas marcar
SKIP_NSFW=false

# Pasta (absoluta ou relativa) onde as mídias ficam salvas
STICKERS_DIR=stickers

# Porta do servidor web (se você expõe UI/endpoint)
#PORT=3000

# Ambiente: development | production
#NODE_ENV=development

# Ajustes de IA (opcionais)
#OPENAI_MODEL=gpt-4o
#OPENAI_TEMPERATURE=0.2
